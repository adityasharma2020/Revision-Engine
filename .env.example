# ---------------------------------------------------------------------------
# UPSC Revision Engine — environment variables
#
# Copy this file to `.env` and fill in the real values. NEVER commit `.env`.
# Only VITE_-prefixed vars are exposed to the client (that is intentional and
# safe here: Supabase's anon key is public by design, protected by Row Level
# Security — never put a service_role key or any secret in a VITE_ var).
# ---------------------------------------------------------------------------

# --- App ---
VITE_APP_NAME="UPSC Revision Engine"
# development | production
VITE_ENVIRONMENT=development
VITE_ENABLE_ANALYTICS=false

# --- Supabase ---  (Project → Settings → API)
# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=
# Public anon/publishable key (safe for the browser; RLS enforces access)
VITE_SUPABASE_ANON_KEY=

# --- Auth (optional toggles) ---
# Allow using the app with no account (fully local, offline). Recommended: true
VITE_ENABLE_GUEST_MODE=true
# Comma-separated: google,email
VITE_AUTH_PROVIDERS=google,email
